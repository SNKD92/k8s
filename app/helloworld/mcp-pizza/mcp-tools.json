{
  "server": {
    "name": "pizza-place-mcp",
    "version": "1.1.0",
    "description": "MCP-ready pizza ordering tools exposed by the /mcp-pizza demo chat.",
    "basePath": "/mcp-pizza"
  },
  "transport": {
    "mode": "browser-demo+http",
    "httpEndpoint": "/mcp-pizza/api/tools/call",
    "jsonRpcMethod": "tools/call",
    "notes": [
      "Tools are available in browser UI and via direct HTTP endpoint for agent integrations.",
      "Direct endpoint accepts both {\"tool\":...,\"arguments\":...} and JSON-RPC tools/call payloads.",
      "The web UI also supports low-tech natural-language ordering and one-click actions.",
      "HTTP endpoint stores server-side order state for tracking IDs and follow-up calls."
    ]
  },
  "references": [
    {
      "name": "pizza_mcp_contract",
      "description": "Tool contract JSON for personal agents.",
      "url": "/mcp-pizza/mcp-tools.json"
    },
    {
      "name": "pizza_chat_ui",
      "description": "Interactive MCP-ready pizza chat page.",
      "url": "/mcp-pizza"
    },
    {
      "name": "pizza_http_tools_call",
      "description": "Direct tool-call endpoint for personal agents.",
      "url": "/mcp-pizza/api/tools/call"
    },
    {
      "name": "mcp_official_docs",
      "description": "Official Model Context Protocol documentation.",
      "url": "https://modelcontextprotocol.io"
    },
    {
      "name": "pizza_ui_source",
      "description": "Source implementation for the pizza MCP page.",
      "url": "https://github.com/SNKD92/k8s/blob/main/app/helloworld/mcp-pizza/index.html"
    },
    {
      "name": "pizza_api_source",
      "description": "Source implementation for the direct HTTP tools endpoint.",
      "url": "https://github.com/SNKD92/k8s/blob/main/app/helloworld/pizza-api/api_server.py"
    }
  ],
  "tools": [
    {
      "name": "get_menu",
      "description": "Return pizza place menu, sizes, extras, and prices.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "category": {
            "type": "string",
            "enum": ["pizza", "salad", "side", "drink"],
            "description": "Optional category filter."
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "create_order",
      "description": "Create a new draft order.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "customerName": { "type": "string" },
          "phone": { "type": "string" },
          "orderType": {
            "type": "string",
            "enum": ["pickup", "delivery"]
          },
          "address": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "update_order_details",
      "description": "Update customer/order settings like delivery mode, address, phone, and name.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "customerName": { "type": "string" },
          "phone": { "type": "string" },
          "orderType": {
            "type": "string",
            "enum": ["pickup", "delivery"]
          },
          "address": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "add_item",
      "description": "Add a menu item to the active order.",
      "inputSchema": {
        "type": "object",
        "required": ["itemId"],
        "properties": {
          "orderId": { "type": "string" },
          "itemId": { "type": "string" },
          "size": {
            "type": "string",
            "enum": ["small", "medium", "large"]
          },
          "quantity": {
            "type": "integer",
            "minimum": 1,
            "maximum": 20
          },
          "extras": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "update_item",
      "description": "Update an existing order line (size, quantity, item, or extras). If lineId is omitted, last relevant line is used.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "orderId": { "type": "string" },
          "lineId": {
            "type": "integer",
            "minimum": 1
          },
          "itemId": { "type": "string" },
          "size": {
            "type": "string",
            "enum": ["small", "medium", "large"]
          },
          "quantity": {
            "type": "integer",
            "minimum": 1,
            "maximum": 20
          },
          "extras": {
            "type": "array",
            "items": { "type": "string" }
          },
          "preferPizza": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "add_extras",
      "description": "Add extras to an existing line (lineId optional).",
      "inputSchema": {
        "type": "object",
        "required": ["extras"],
        "properties": {
          "orderId": { "type": "string" },
          "lineId": {
            "type": "integer",
            "minimum": 1
          },
          "itemId": { "type": "string" },
          "preferPizza": { "type": "boolean" },
          "extras": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "remove_extras",
      "description": "Remove extras from an existing line (lineId optional).",
      "inputSchema": {
        "type": "object",
        "required": ["extras"],
        "properties": {
          "orderId": { "type": "string" },
          "lineId": {
            "type": "integer",
            "minimum": 1
          },
          "itemId": { "type": "string" },
          "preferPizza": { "type": "boolean" },
          "extras": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "remove_item",
      "description": "Remove an order line by lineId.",
      "inputSchema": {
        "type": "object",
        "required": ["lineId"],
        "properties": {
          "orderId": { "type": "string" },
          "lineId": {
            "type": "integer",
            "minimum": 1
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "get_order",
      "description": "Return the current order details and subtotal.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "orderId": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "track_order",
      "description": "Track an order by orderId. If omitted, latest active/tracked order is used.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "orderId": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "list_orders",
      "description": "List recent tracked orders from local demo history.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 20
          }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "place_order",
      "description": "Mark the draft order as placed.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "orderId": { "type": "string" },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    {
      "name": "get_bill",
      "description": "Return itemized bill with subtotal, tax, fees, tip, and final total.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "orderId": { "type": "string" },
          "tipPercent": {
            "type": "number",
            "minimum": 0,
            "maximum": 40
          }
        },
        "additionalProperties": false
      }
    }
  ],
  "sampleToolCall": {
    "tool": "add_item",
    "arguments": {
      "orderId": "PZ-1001",
      "itemId": "margherita",
      "size": "large",
      "quantity": 1,
      "extras": ["extra-cheese"]
    }
  },
  "sampleJsonRpcCall": {
    "jsonrpc": "2.0",
    "id": "42",
    "method": "tools/call",
    "params": {
      "name": "get_bill",
      "arguments": {
        "orderId": "PZ-1001",
        "tipPercent": 12
      }
    }
  },
  "sampleSequence": [
    {
      "tool": "create_order",
      "arguments": {
        "customerName": "Alex",
        "orderType": "pickup"
      }
    },
    {
      "tool": "add_item",
      "arguments": {
        "orderId": "PZ-1001",
        "itemId": "margherita",
        "size": "large",
        "quantity": 1
      }
    },
    {
      "tool": "place_order",
      "arguments": {
        "orderId": "PZ-1001"
      }
    },
    {
      "tool": "track_order",
      "arguments": {
        "orderId": "PZ-1001"
      }
    }
  ]
}
